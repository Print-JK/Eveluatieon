{
  "manifest_version": 3,
  "name": "Eveluatieon",
  "version": "0.1.0",
  "description": "Firefox extension for website security auditing and human-readable security insights.",

  "permissions": [
    "activeTab"
    ,"tabs"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "scripts": [
      "src/background/background.js"
    ]
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/content.js"]
    }
  ],

  "action": {
    "default_popup": "src/popup/popup.html"
  }
}

    